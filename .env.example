# CinaConnect — Environment Variables
# Copy to .env and fill in values. Do NOT commit .env.

# === Relay Server ===
RELAY_LISTEN_ADDR=0.0.0.0:8080
RELAY_REDIS_URL=redis://redis:6379
RELAY_NATS_URL=nats://nats-cluster:4222
RELAY_REGION=local
RELAY_PUBLIC_URL=ws://localhost:5555
RELAY_PROJECT_ID=your-project-id

# TLS (optional — leave empty for plaintext)
# RELAY_TLS_CERT=/path/to/cert.pem
# RELAY_TLS_KEY=/path/to/key.pem

# === Database (PostgreSQL) ===
POSTGRES_USER=cinaconnect
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=cinaconnect
ENCRYPTION_KEY=<GENERATE_A_SECURE_KEY>

# === RPC Providers ===
ETHEREUM_RPC_URL=https://eth-mainnet.example.com/v1/your-api-key
ARBITRUM_RPC_URL=https://arb-mainnet.example.com/v1/your-api-key

# === Demo App ===
NEXT_PUBLIC_PROJECT_ID=your-project-id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-wc-project-id
