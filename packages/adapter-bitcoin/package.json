{
  "name": "@cinacoin/adapter-bitcoin",
  "version": "1.0.0",
  "description": "Native Bitcoin wallet connectors for Cinacoin — Unisat, Leather, OKX, SatsConnect, Xverse, Wallet Standard",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "@cinacoin/core-sdk": "workspace:*"
  },
  "dependencies": {
    "@sats-connect/core": "^0.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
