{
  "name": "@cinacoin/relay-server",
  "version": "0.2.0",
  "description": "WalletConnect relay server for Cinacoin — HTTP/WebSocket relay interface",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@cinacoin/core-sdk": "workspace:*",
    "@cinacoin/walletconnect-v2": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}
