  },
  "dependencies": {
    "@cinacoin/core-sdk": "^0.2.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cinagroup/Cinacoin.git",
    "directory": "packages/multiwallet"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
