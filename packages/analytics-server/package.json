{
  "name": "@cinacoin/analytics-server",
  "version": "0.1.0",
  "description": "Cinacoin Analytics Ingestion Server — Cloudflare Worker",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outdir=dist --format=esm --platform=browser --target=es2022 --sourcemap",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "wrangler d1 migrations apply CinacoinAnalytics --local",
    "db:migrate:prod": "wrangler d1 migrations apply CinacoinAnalytics --remote",
    "db:create": "wrangler d1 create CinacoinAnalytics"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "vitest": "^2.1.0",
    "@cloudflare/workers-types": "^4.20260530.1"
  },
  "license": "MIT",
  "private": true,
  "sideEffects": false
}
