{
  "name": "@onchainux/passkey-auth",
  "version": "0.1.0",
  "description": "OnChainUX Passkey Auth — WebAuthn-based authentication for blockchain apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
