{
  "name": "@cinaconnect/svelte",
  "version": "0.1.0",
  "description": "Svelte/SvelteKit adapter for CinaConnect wallet connection toolkit",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./kit": {
      "import": "./dist/kit/index.js",
      "types": "./dist/kit/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cinaconnect/core-sdk": "file:../core-sdk"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0",
    "@sveltejs/kit": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "@testing-library/svelte": "^5.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.2.0"
  },
  "license": "MIT",
  "keywords": ["svelte", "sveltekit", "wallet", "web3", "cinaconnect", "ethereum", "crypto"]
}
