{
  "name": "@cinacoin/react",
  "version": "0.2.0",
  "description": "React adapter for Cinacoin white-label UI toolkit",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cinacoin/core-sdk": "workspace:*",
    "@cinacoin/core-ui": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "1",
    "jsdom": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.2.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
