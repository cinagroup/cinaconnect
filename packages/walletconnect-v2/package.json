{
  "name": "@onchainux/walletconnect-v2",
  "version": "0.1.0",
  "description": "WalletConnect v2 protocol implementation for OnChainUX — pairing, session, crypto, relay, and RPC methods",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@onchainux/core-sdk": "workspace:*",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "viem": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "files": ["dist"],
  "type": "module",
  "sideEffects": false
}
