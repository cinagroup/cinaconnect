# Social Login Server Deployment Environment Variables
# Copy to .env and fill in values before deploying.

# ─── Google OAuth2 ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ─── Apple Sign-In ──────────────────────────────────────────────
APPLE_CLIENT_ID=com.your-app.web
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id
APPLE_PRIVATE_KEY_PATH=./secrets/apple/AuthKey.p8
APPLE_REDIRECT_URI=https://your-domain.com/auth/apple/callback

# ─── Twitter/X OAuth2 ───────────────────────────────────────────
TWITTER_CLIENT_ID=your-twitter-api-key
TWITTER_CLIENT_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_REDIRECT_URI=https://your-domain.com/auth/twitter/callback

# ─── GitHub OAuth2 ──────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://your-domain.com/auth/github/callback

# ─── Session / JWT ──────────────────────────────────────────────
SESSION_SECRET=your-32-byte-hex-session-secret
JWT_SECRET=your-32-byte-hex-jwt-secret
JWT_EXPIRY_SECONDS=86400

# ─── Database (for session persistence) ─────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/cinaconnect-social

# ─── Redis (for rate limiting and OTP caching) ──────────────────
REDIS_URL=redis://localhost:6379

# ─── SMS / Email (optional — for OTP-based login) ───────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+1234567890
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM=CinaConnect
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# ─── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGINS=https://your-domain.com
