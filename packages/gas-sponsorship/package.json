{
  "name": "@cinacoin/gas-sponsorship",
  "version": "0.2.0",
  "description": "Enterprise gas sponsorship for smart accounts via paymaster integration.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "viem": ">=2.0.0"
  },
  "dependencies": {
    "@cinacoin/core-sdk": "workspace:*",
    "@cinacoin/aa-sdk": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cinagroup/Cinacoin.git",
    "directory": "packages/gas-sponsorship"
  },
  "publishConfig": {
    "access": "public"
  }
}
