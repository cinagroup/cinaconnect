{
  "name": "@cinacoin/next",
  "version": "0.2.0",
  "description": "Next.js SSR-optimized support for Cinacoin — App Router & Pages Router integration",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./app-router": {
      "import": "./dist/app-router/index.js",
      "types": "./dist/app-router/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "viem": "^2.0.0"
  },
  "dependencies": {
    "@cinacoin/core-sdk": "workspace:*",
    "@cinacoin/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.3.0",
    "viem": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
