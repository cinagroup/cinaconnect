{
  "name": "@cinacoin/embedded-wallet",
  "version": "0.2.0",
  "description": "Embedded wallet system with email, social, and phone authentication",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cinagroup/Cinacoin.git",
    "directory": "packages/embedded-wallet"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "wallet",
    "embedded-wallet",
    "secp256k1",
    "web3",
    "auth"
  ],
  "publishConfig": {
    "access": "public"
  }
}
