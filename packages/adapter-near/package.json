{
  "name": "@cinacoin/adapter-near",
  "version": "1.0.0",
  "description": "Cinacoin NEAR chain adapter — NEAR Wallet, Here Wallet, Meteor Wallet support",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./connectors/near-wallet": {
      "import": "./dist/connectors/near-wallet.js",
      "require": "./dist/connectors/near-wallet.js",
      "types": "./dist/connectors/near-wallet.d.ts"
    },
    "./connectors/here-wallet": {
      "import": "./dist/connectors/here-wallet.js",
      "require": "./dist/connectors/here-wallet.js",
      "types": "./dist/connectors/here-wallet.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "peerDependencies": {
    "@cinacoin/core-sdk": ">=0.2.0",
    "@near-wallet-selector/core": ">=8.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module"
}
