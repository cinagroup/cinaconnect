{
  "name": "@onchainux/testing",
  "version": "0.1.0",
  "description": "Testing utilities for OnChainUX — mock providers, wallets, chains, and transactions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "onchainux",
    "testing",
    "mock",
    "eip-1193",
    "ethereum",
    "web3"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
