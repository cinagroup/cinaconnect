{
  "name": "@cinacoin/core-sdk",
  "version": "0.2.0",
  "description": "Cinacoin Core SDK — Self-hosted wallet connection toolkit",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:direct": "npx tsx tests/*.test.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@cinacoin/siwe": "workspace:*",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "viem": "^2.9.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "1",
    "eslint": "^8.56.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
